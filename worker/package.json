{
  "name": "@shelf-analysis/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply shelf-analysis-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply shelf-analysis-db --remote",
    "seed:admin": "npx tsx scripts/seed-admin-cli.ts",
    "seed:admin:local": "npx tsx scripts/seed-admin-cli.ts --apply-local"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250617.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.0"
  }
}
